# ============================================================
# BIENESTAR INTEGRAL PLATFORM — Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ─── Entorno ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Base de datos ───────────────────────────────────────────
# PostgreSQL (producción — Coolify/DigitalOcean):
DATABASE_URL="postgresql://bienestar:TU_PASSWORD_AQUI@db:5432/bienestar"

# SQLite (solo desarrollo local):
# DATABASE_URL="file:./prisma/dev.db"

# ─── Autenticación JWT ───────────────────────────────────────
# Genera uno seguro con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-muy-largo-y-aleatorio

# ─── CORS ────────────────────────────────────────────────────
# Desarrollo: dejar en blanco (usará http://localhost:5173 por defecto)
# Producción: URL exacta del dominio donde corre el frontend
ALLOWED_ORIGIN=https://tudominio.com

# ─── Google Gemini AI ────────────────────────────────────────
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# ─── Email / Notificaciones (opcional) ───────────────────────
# Usa Gmail, Outlook, Mailgun, SendGrid, etc.
# Gmail: activa "contraseñas de aplicación" en cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contrasena-de-aplicacion
SMTP_FROM="Bienestar Integral <tu-correo@gmail.com>"

# ─── 2FA (opcional — se genera automáticamente al activar) ───
# No requiere configuración manual; se genera en /api/auth/2fa/setup
